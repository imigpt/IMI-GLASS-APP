<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">


    <!-- STORAGE / MEDIA -->


    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" tools:ignore="ScopedStorage" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" tools:ignore="ScopedStorage" />

    <!-- LOCATION -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- INTERNET -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- BLUETOOTH -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true" />

    <!-- AUDIO -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- CAMERA -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- NOTIFICATIONS -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ACCESSIBILITY -->

    <!-- CONTACTS / CALLS -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.CALL_PHONE" />

    <!-- WIFI -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="s" />

    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
        <package android:name="com.spotify.music" />
        <intent>
            <action android:name="android.media.action.MEDIA_PLAY_FROM_SEARCH" />
        </intent>
    </queries>

    <application
        android:name=".ui.MyApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.GlassesSDKSample"
        android.usesCleartextTraffic="true"
        android:id="@+id/etCommand"

        tools:targetApi="31">

        <!-- SPLASH SCREEN -->
        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.App.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- AUTHENTICATION SCREENS -->
        <activity
            android:name=".LoginActivity"
            android:exported="false" />
        
        <activity
            android:name=".SignUpActivity"
            android:exported="false" />
        
        <activity
            android:name=".VerifyCodeActivity"
            android:exported="false" />

        <!-- ONBOARDING SCREEN -->
        <activity
            android:name=".ui.OnboardingActivity"
            android:exported="false" />

        <!-- MAIN SCREEN -->
        <activity
            android:name=".MainActivity"
            android:exported="true" />

        <!-- TOP-LEVEL CAMERA TAB -->
        <activity
            android:name=".CameraActivity"
            android:exported="false"
            android:label="Camera" />

        <!-- TOP-LEVEL SETTINGS TAB -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="Settings" />

        <!-- BATTERY STATUS SCREEN -->
        <activity
            android:name=".BatteryActivity"
            android:exported="false"
            android:label="Battery" />

        <!-- TOP-LEVEL MORE TAB -->
        <activity
            android:name=".MoreActivity"
            android:exported="false"
            android:label="More" />

        <!-- BIND DEVICE -->
        <activity android:name=".ui.DeviceBindActivity" />

        <!-- USER MEMORY SETTINGS -->
        <activity 
            android:name=".ui.UserMemoryActivity"
            android:exported="false"
            android:label="AI Memory Settings" />

        <!-- 15-QUESTION PROFILE BUILDER -->
        <activity
            android:name=".ui.LetUsKnowYouActivity"
            android:exported="false"
            android:label="Let Us Know You" />

        <!-- PROFILE SCREEN -->
        <activity 
            android:name=".ProfileActivity"
            android:exported="false"
            android:label="Profile" />

        <!-- GEMINI LIVE CONVERSATION -->
        <activity 
            android:name=".ui.GeminiLiveActivity"
            android:exported="true"
            android:label="Gemini Live Conversation" />

        <!-- VISION CHAT - IMAGE ANALYSIS -->
        <activity 
            android:name=".VisionChatActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:label="Vision Chat" />

        <!-- CHAT - AI CONVERSATION WITH DRAWER -->
        <activity 
            android:name=".ui.ChatActivity"
            android:exported="false"
            android:label="Chat" />

        <!-- CONVERSATION HISTORY - ALL USER/AI MESSAGES -->
        <activity
            android:name=".ui.ConversationHistoryActivity"
            android:exported="false"
            android:label="Conversation History" />

        <!-- USER AI SUMMARY - PROFILE SNAPSHOT FROM CONVERSATION + MEMORY -->
        <activity
            android:name=".ui.UserProfileSummaryActivity"
            android:exported="false"
            android:label="User AI Summary" />

        <!-- QUICK NOTES - USER NOTES AND AI REMINDERS -->
        <activity 
            android:name=".ui.QuickNotesActivity"
            android:exported="false"
            android:label="Quick Notes" />
            
        <!-- MEETING MINUTES - SPEECH-TO-TEXT AND SUMMARIZATION -->
        <activity
            android:name=".ui.MeetingMinutesActivity"
            android:exported="false"
            android:label="Meeting Minutes" />
            
        <activity
            android:name=".ui.ActiveMeetingActivity"
            android:exported="false"
            android:label="Recording Meeting" />

            <!-- BLE PCM TEST ACTIVITY -->
            <activity
                android:name=".ui.BlePcmTestActivity"
                android:exported="true"
                android:label="BLE PCM Test" />

            <!-- GLASS MEDIA GALLERY -->
            <activity
                android:name=".ui.gallery.GlassMediaGalleryActivity"
                android:exported="false"
                android:label="Glass Media Gallery" />

            <!-- LIVE GALLERY – locally captured photos from glasses -->
            <activity
                android:name=".ui.gallery.LiveGalleryActivity"
                android:exported="false"
                android:label="Live Gallery" />

            <!-- IMAGE VIEWER - Full screen in-app image viewer -->
            <activity
                android:name=".ui.gallery.ImageViewerActivity"
                android:exported="false"
                android:theme="@style/Theme.GlassesSDKSample.Fullscreen"
                android:label="Image Viewer" />

            <!-- IMAGE DESCRIPTION VAULT – hidden page (long-press photo count in LiveGallery) -->
            <activity
                android:name=".ui.gallery.ImageDescriptionVaultActivity"
                android:exported="false"
                android:label="Descriptions Vault" />

            <!-- VIDEO PLAYER - Full screen in-app video player -->
            <activity
                android:name=".ui.gallery.VideoPlayerActivity"
                android:exported="false"
                android:theme="@style/Theme.GlassesSDKSample.Fullscreen"
                android:label="Video Player"
                android:configChanges="orientation|screenSize" />

            <!-- FILE PROVIDER FOR SHARING MEDIA -->
            <provider
                android:name="androidx.core.content.FileProvider"
                android:authorities="${applicationId}.fileprovider"
                android:exported="false"
                android:grantUriPermissions="true">
                <meta-data
                    android:name="android.support.FILE_PROVIDER_PATHS"
                    android:resource="@xml/file_paths" />
            </provider>

            <!-- BACKGROUND LISTENING SERVICE -->
            <service
                android:name=".ListeningService"
                android:exported="false" />

            <!-- NOTIFICATION LISTENER SERVICE -->
            <service
                android:name=".NotificationListener"
                android:exported="true"
                android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
                <intent-filter>
                    <action android:name="android.service.notification.NotificationListenerService" />
                </intent-filter>
            </service>

            <!-- WHATSAPP AUTO-SEND ACCESSIBILITY SERVICE -->
            <service
                android:name=".WhatsAppAutoSendService"
                android:exported="true"
                android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
                <intent-filter>
                    <action android:name="android.accessibilityservice.AccessibilityService" />
                </intent-filter>
                <meta-data
                    android:name="android.accessibilityservice"
                    android:resource="@xml/accessibility_service_config" />
            </service>

    </application>

</manifest>
