<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main glass-themed gradient background -->
    <item android:drawable="@drawable/bg_app_gradient" />

    <!-- Soft top haze -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#46FFFFFF"
                android:centerColor="#1FFFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

    <!-- Bottom cyan glow -->
    <item android:gravity="bottom" android:height="240dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#1C00D9FF"
                android:endColor="#0000D9FF" />
        </shape>
    </item>
</layer-list>
