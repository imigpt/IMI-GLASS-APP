<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#40F59E0B">
    
    <item>
        <layer-list>
            <!-- Shadow -->
            <item android:top="1dp" android:bottom="4dp" android:left="1dp" android:right="1dp">
                <shape android:shape="rectangle">
                    <corners android:radius="16dp" />
                    <solid android:color="#1A000000" />
                </shape>
            </item>
            
            <!-- Main Button -->
            <item android:bottom="3dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="135"
                        android:startColor="#FFF59E0B"
                        android:centerColor="#FFE58D05"
                        android:endColor="#FFD97706"
                        android:type="linear" />
                    <corners android:radius="16dp" />
                    <stroke
                        android:width="1dp"
                        android:color="#80F59E0B" />
                </shape>
            </item>
            
            <!-- Shine Effect -->
            <item android:top="0dp" android:bottom="20dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="90"
                        android:startColor="#48FFFFFF"
                        android:endColor="#00FFFFFF"
                        android:type="linear" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    
</ripple>
