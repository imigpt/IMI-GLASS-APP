<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#40FFFFFF">
    
    <item>
        <layer-list>
            <!-- Shadow -->
            <item android:top="1dp" android:bottom="4dp" android:left="1dp" android:right="1dp">
                <shape android:shape="rectangle">
                    <corners android:radius="16dp" />
                    <solid android:color="#20000000" />
                </shape>
            </item>
            
            <!-- Main Button -->
            <item android:bottom="3dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="135"
                        android:startColor="#D4D6D8"
                        android:centerColor="#B8BABC"
                        android:endColor="#9A9FA6"
                        android:type="linear" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
            
            <!-- Shine Effect -->
            <item android:top="0dp" android:bottom="20dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="90"
                        android:startColor="#30FFFFFF"
                        android:endColor="#00FFFFFF"
                        android:type="linear" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    
</ripple>
