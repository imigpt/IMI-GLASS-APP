<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#30FFFFFF">
    
    <item>
        <layer-list>
            <!-- Main Button -->
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="135"
                        android:startColor="#2A2F33"
                        android:centerColor="#252A2E"
                        android:endColor="#1F2428"
                        android:type="linear" />
                    <corners android:radius="14dp" />
                    <stroke
                        android:width="1dp"
                        android:color="#3D4247" />
                </shape>
            </item>
            
            <!-- Glass Reflection -->
            <item android:top="0dp" android:bottom="24dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="90"
                        android:startColor="#15FFFFFF"
                        android:endColor="#00FFFFFF"
                        android:type="linear" />
                    <corners android:radius="14dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    
</ripple>
