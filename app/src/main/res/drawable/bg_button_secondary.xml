<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#336B7280">
    
    <item>
        <layer-list>
            <!-- Main Button -->
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="135"
                        android:startColor="#FF2F2F2F"
                        android:centerColor="#FF2B2B2B"
                        android:endColor="#FF242424"
                        android:type="linear" />
                    <corners android:radius="14dp" />
                    <stroke
                        android:width="1dp"
                        android:color="#14FFFFFF" />
                </shape>
            </item>
            
            <!-- Glass Reflection -->
            <item android:top="0dp" android:bottom="24dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="90"
                        android:startColor="#55FFFFFF"
                        android:endColor="#00FFFFFF"
                        android:type="linear" />
                    <corners android:radius="14dp" />
                </shape>
            </item>
        </layer-list>
    </item>

</ripple>
