<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#2FFFFFFF">

    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="28dp" />
                    <gradient
                        android:angle="135"
                        android:startColor="#FF7F2E"
                        android:endColor="#D87D41"
                        android:type="linear" />
                </shape>
            </item>

            <item android:top="0dp" android:bottom="22dp">
                <shape android:shape="rectangle">
                    <corners android:radius="28dp" />
                    <gradient
                        android:angle="90"
                        android:startColor="#33FFFFFF"
                        android:endColor="#00FFFFFF"
                        android:type="linear" />
                </shape>
            </item>
        </layer-list>
    </item>

</ripple>