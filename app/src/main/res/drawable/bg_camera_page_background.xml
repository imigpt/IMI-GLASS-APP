<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#FF17191D"
                android:centerColor="#FF14161A"
                android:endColor="#FF101216"
                android:type="linear" />
        </shape>
    </item>

    <item android:gravity="top|start" android:width="460dp" android:height="460dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:startColor="#1E8D96A1"
                android:endColor="#008D96A1"
                android:gradientRadius="310dp" />
        </shape>
    </item>

    <item android:gravity="bottom|end" android:width="500dp" android:height="500dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:startColor="#149CA3AD"
                android:endColor="#009CA3AD"
                android:gradientRadius="340dp" />
        </shape>
    </item>

</layer-list>
