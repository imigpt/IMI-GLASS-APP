<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#FF1C1A17"
                android:centerColor="#FF15130F"
                android:endColor="#FF0F0D0B"
                android:type="linear" />
        </shape>
    </item>

    <item android:gravity="top|start" android:width="460dp" android:height="460dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:startColor="#26FF7F2E"
                android:endColor="#00FF7F2E"
                android:gradientRadius="310dp" />
        </shape>
    </item>

    <item android:gravity="bottom|end" android:width="500dp" android:height="500dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:startColor="#18D87D41"
                android:endColor="#00D87D41"
                android:gradientRadius="340dp" />
        </shape>
    </item>

</layer-list>
