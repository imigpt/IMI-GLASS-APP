<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="26dp" />
            <gradient
                android:angle="315"
                android:startColor="#FF2A3038"
                android:centerColor="#FF232931"
                android:endColor="#FF1D232A"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#338D99A6" />
        </shape>
    </item>

</layer-list>
