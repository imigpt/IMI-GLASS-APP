<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Soft Shadow Layer -->
    <item android:top="2dp" android:bottom="6dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="#22000000" />
        </shape>
    </item>
    
    <!-- Main Card with Gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#FF35383D"
                android:centerColor="#FF32353A"
                android:endColor="#FF2F3136"
                android:type="linear" />
            <corners android:radius="20dp" />
            <stroke
                android:width="1.5dp"
                android:color="#1AFFFFFF" />
        </shape>
    </item>
    
    <!-- Top Highlight for Glass Effect -->
    <item android:top="0dp" android:bottom="160dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#56FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <item android:gravity="bottom" android:height="80dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#269EA6AF"
                android:endColor="#009EA6AF"
                android:type="linear" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    
</layer-list>
