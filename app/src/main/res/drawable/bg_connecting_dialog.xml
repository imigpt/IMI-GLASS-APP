<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <gradient
                android:angle="135"
                android:startColor="#EF313338"
                android:centerColor="#F035383E"
                android:endColor="#EE2D3036"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#24FFFFFF" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="21dp" />
            <gradient
                android:angle="90"
                android:startColor="#22FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear" />
        </shape>
    </item>

    <item
        android:gravity="bottom"
        android:height="84dp">
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <gradient
                android:angle="90"
                android:startColor="#2800D9FF"
                android:endColor="#0000D9FF"
                android:type="linear" />
        </shape>
    </item>

</layer-list>
