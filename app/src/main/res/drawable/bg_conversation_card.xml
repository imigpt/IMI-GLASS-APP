<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    
    <!-- Conversation card gradient -->
    <gradient
        android:angle="90"
        android:startColor="#1E2225"
        android:centerColor="#1B1E21"
        android:endColor="#181B1E"
        android:type="linear" />
    
    <!-- Rounded corners -->
    <corners android:radius="20dp" />
    
    <!-- Border with glow effect -->
    <stroke
        android:width="1.5dp"
        android:color="#3A3E42" />
        
</shape>
