<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Nav pill -->
    <item>
        <shape>
            <solid android:color="#2B2B2B" />
            <corners android:radius="40dp" />
            <stroke android:width="1dp" android:color="#22FFFFFF" />
        </shape>
    </item>
    <!-- Orange accent glow strip at top-left -->
    <item
        android:left="56dp"
        android:right="180dp"
        android:top="0dp"
        android:bottom="64dp">
        <shape>
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#00FF7F2E"
                android:centerColor="#FFFF7F2E"
                android:endColor="#00FF7F2E" />
            <corners android:radius="2dp" />
        </shape>
    </item>
</layer-list>
