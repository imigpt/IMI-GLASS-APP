<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Nav pill -->
    <item>
        <shape>
            <solid android:color="#2B2B2B" />
            <corners android:radius="40dp" />
            <stroke android:width="1dp" android:color="#22FFFFFF" />
        </shape>
    </item>
    <!-- Orange accent glow strip is drawn programmatically above the selected
         item in BottomNavManager (see nav_selected_glow). -->
</layer-list>
