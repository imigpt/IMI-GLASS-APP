<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer shadow/glow -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#20FFFFFF" />
            <size
                android:width="56dp"
                android:height="56dp" />
        </shape>
    </item>
    
    <!-- Glass effect circle -->
    <item
        android:top="2dp"
        android:left="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="oval">
            <solid android:color="#50505050" />
        </shape>
    </item>
</layer-list>
