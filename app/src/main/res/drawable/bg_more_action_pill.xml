<?xml version="1.0" encoding="utf-8"?>
<!-- Camera / Vision Chat pill.
     Figma: same radial(ellipse at 43% top, rgba(255,127,46,0.64) -> rgba(28,27,51,0.13))
     under a 39% black overlay, border 0.18px #FF6900, radius 63.98. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="120dp"
                android:centerX="0.43"
                android:centerY="0.0"
                android:startColor="#7AFF7F2E"
                android:centerColor="#2E1C1B33"
                android:endColor="#231C1B33" />
            <corners android:radius="64dp" />
            <stroke android:width="1dp" android:color="#FF6900" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#63000000" />
            <corners android:radius="64dp" />
            <stroke android:width="1dp" android:color="#FF6900" />
        </shape>
    </item>
</layer-list>
