<?xml version="1.0" encoding="utf-8"?>
<!-- More screen background: Figma base #272626 with a warm orange glow
     clustered around the upper-centre (behind the Recents card). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#272626" />
        </shape>
    </item>

    <!-- Orange glow behind the title + recents card -->
    <item android:gravity="center_horizontal|top" android:width="640dp" android:height="560dp" android:top="-60dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="330dp"
                android:startColor="#73FF6900"
                android:centerColor="#33C8541A"
                android:endColor="#00272626" />
        </shape>
    </item>

</layer-list>
