<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:angle="270"
                android:startColor="#7CB8BABC"
                android:endColor="#7C9A9FA6" />
            <stroke
                android:width="1dp"
                android:color="#AAE8EAEC" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:angle="270"
                android:startColor="#B8BABC"
                android:endColor="#8E9A9FA6" />
            <stroke
                android:width="1dp"
                android:color="#CCE8EAEC" />
        </shape>
    </item>
</selector>
