<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="360dp"
    android:height="640dp"
    android:viewportWidth="360"
    android:viewportHeight="640">
    
    <!-- Gray fog effect gradient -->
    <path android:pathData="M0,0 L360,0 L360,640 L0,640 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="180"
                android:centerY="320"
                android:gradientRadius="400">
                <item android:color="#20FFFFFF" android:offset="0.0"/>
                <item android:color="#10FFFFFF" android:offset="0.5"/>
                <item android:color="#00FFFFFF" android:offset="1.0"/>
            </gradient>
        </aapt:attr>
    </path>
</vector>
