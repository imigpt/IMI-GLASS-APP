<?xml version="1.0" encoding="utf-8"?>
<!-- Round voice/waveform button at the end of the composer -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#33FFFFFF">
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="22dp"
                android:startColor="#4D4A4A4A"
                android:endColor="#33312A24" />
            <stroke
                android:width="1dp"
                android:color="#59FFFFFF" />
        </shape>
    </item>
</ripple>
