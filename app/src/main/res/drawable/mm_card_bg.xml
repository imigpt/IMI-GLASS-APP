<?xml version="1.0" encoding="utf-8"?>
<!-- Translucent dark card with subtle orange border for meeting list items -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="135"
        android:startColor="#33402411"
        android:endColor="#26201A16"
        android:type="linear" />
    <corners android:radius="18dp" />
    <stroke
        android:width="1dp"
        android:color="#33FF7F2E" />
</shape>
