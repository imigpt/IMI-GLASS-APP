<?xml version="1.0" encoding="utf-8"?>
<!-- Centered dialog card background with orange border, matching mockups -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="135"
        android:startColor="#3A2A14"
        android:endColor="#1E1814"
        android:type="linear" />
    <corners android:radius="20dp" />
    <stroke
        android:width="1dp"
        android:color="#66FF7F2E" />
</shape>
