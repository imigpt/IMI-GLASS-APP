<?xml version="1.0" encoding="utf-8"?>
<!-- Rounded floating card for the meeting details dialog (orange theme) -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="135"
        android:startColor="#33402411"
        android:endColor="#1A1410"
        android:type="linear" />
    <corners android:radius="22dp" />
    <stroke
        android:width="1dp"
        android:color="#4DFF7F2E" />
</shape>
