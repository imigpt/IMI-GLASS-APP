<?xml version="1.0" encoding="utf-8"?>
<!-- Glowing circular mic button for the list screen "Start Meeting Minutes" -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#33FFFFFF">
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="60dp"
                android:startColor="#FF8C3A"
                android:endColor="#A8431B" />
            <stroke
                android:width="1dp"
                android:color="#66FF7F2E" />
        </shape>
    </item>
</ripple>
