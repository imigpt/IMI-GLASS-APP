<?xml version="1.0" encoding="utf-8"?>
<!-- AI-written note card with orange outline (AI Written list) -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="135"
        android:startColor="#26402411"
        android:endColor="#1A201A16"
        android:type="linear" />
    <corners android:radius="16dp" />
    <stroke
        android:width="1dp"
        android:color="#80FF7F2E" />
</shape>
