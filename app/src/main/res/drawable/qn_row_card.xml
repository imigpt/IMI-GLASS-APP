<?xml version="1.0" encoding="utf-8"?>
<!-- Standalone single-note rounded row (e.g. the lone June note) -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="135"
        android:startColor="#2E3A2418"
        android:endColor="#21211F1C"
        android:type="linear" />
    <corners android:radius="16dp" />
    <stroke
        android:width="1dp"
        android:color="#1AFFFFFF" />
</shape>
