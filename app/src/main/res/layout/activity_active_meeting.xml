<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/mm_bg_gradient">

    <!-- Header: back arrow + title -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="40dp"
        android:paddingBottom="12dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:padding="4dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Meeting Minutes"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Title pill -->
    <TextView
        android:id="@+id/tv_meeting_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/mm_title_pill"
        android:gravity="center"
        android:paddingVertical="16dp"
        android:text="Title: Health &amp; Fitness"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Recording status row -->
    <LinearLayout
        android:id="@+id/status_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_meeting_title"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recording audio"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <View
            android:id="@+id/indicator_recording"
            android:layout_width="9dp"
            android:layout_height="9dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/recording_indicator" />

    </LinearLayout>

    <!-- Live participants (hidden until detected) -->
    <TextView
        android:id="@+id/tv_live_participants"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/status_row"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="6dp"
        android:text="👥 Detecting participants…"
        android:textColor="#FF8C3A"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Center area: glowing timer OR summary generation -->
    <FrameLayout
        android:id="@+id/center_area"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/control_bar"
        android:layout_below="@id/tv_live_participants">

        <!-- Soft background glow (behind the blobs, just hugging the inner circle) -->
        <com.sdk.glassessdksample.ui.MeetingGlowView
            android:id="@+id/glow_bg"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_gravity="center" />

        <!-- Glowing timer (visible while recording) -->
        <FrameLayout
            android:id="@+id/timer_container"
            android:layout_width="340dp"
            android:layout_height="340dp"
            android:layout_gravity="center">

            <!-- Animated organic blob glow (5 ellipse layers, morphing) -->
            <com.sdk.glassessdksample.ui.MeetingBlobView
                android:id="@+id/blob_glow"
                android:layout_width="340dp"
                android:layout_height="340dp"
                android:layout_gravity="center" />

            <FrameLayout
                android:layout_width="168dp"
                android:layout_height="168dp"
                android:layout_gravity="center"
                android:background="@drawable/mm_timer_inner">

                <TextView
                    android:id="@+id/tv_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="00 :\n00"
                    android:textColor="#FFFFFF"
                    android:textSize="40sp"
                    android:textStyle="bold" />

            </FrameLayout>

        </FrameLayout>

        <!-- Summary screen (visible after meeting ends) -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/summary_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="18dp"
                android:paddingTop="12dp"
                android:paddingBottom="20dp">

                <!-- Meeting info card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@android:color/transparent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_home_card"
                        android:padding="18dp">

                        <TextView
                            android:id="@+id/tv_summary_meeting_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Title:"
                            android:textColor="#FFFFFF"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tv_summary_date"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="#CCFFFFFF"
                            android:textSize="13sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tv_summary_duration"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="#CCFFFFFF"
                            android:textSize="13sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tv_summary_words"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="#CCFFFFFF"
                            android:textSize="13sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Generating indicator (shown while processing) -->
                <LinearLayout
                    android:id="@+id/layout_generating"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_waveform"
                        app:tint="#FF8C3A" />

                    <TextView
                        android:id="@+id/tv_summary_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Generating Summary…."
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Summary result card (shown after summary is ready) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_summary_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@android:color/transparent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_home_card"
                        android:padding="18dp">

                        <TextView
                            android:id="@+id/tv_transcript"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#E0FFFFFF"
                            android:textSize="14sp"
                            android:lineSpacingMultiplier="1.5"
                            android:layout_marginBottom="20dp" />

                        <!-- Buttons row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="end">

                            <Button
                                android:id="@+id/btn_summary_close"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:text="Close"
                                android:textColor="#CCFFFFFF"
                                android:textSize="13sp"
                                android:background="@android:color/transparent"
                                android:stateListAnimator="@null"
                                android:layout_marginEnd="8dp" />

                            <Button
                                android:id="@+id/btn_summary_view_all"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:text="View All Meetings"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:background="@drawable/bg_home_btn_orange"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:stateListAnimator="@null" />

                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </FrameLayout>

    <!-- Bottom control bar -->
    <LinearLayout
        android:id="@+id/control_bar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/mm_control_bar"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp">

        <!-- Switch / restart — oval pill -->
        <ImageView
            android:id="@+id/btn_switch"
            android:layout_width="72dp"
            android:layout_height="52dp"
            android:background="@drawable/mm_ctrl_circle"
            android:contentDescription="Switch"
            android:padding="14dp"
            android:src="@drawable/ic_sync"
            app:tint="#FFFFFF" />

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Stop (end meeting) — larger circle, bright white border -->
        <ImageView
            android:id="@+id/btn_end_meeting"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:background="@drawable/mm_ctrl_stop"
            android:contentDescription="Stop meeting"
            android:padding="20dp"
            android:src="@drawable/ic_stop_square"
            app:tint="#FFFFFF" />

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Pause / resume — oval pill -->
        <ImageView
            android:id="@+id/btn_pause"
            android:layout_width="72dp"
            android:layout_height="52dp"
            android:background="@drawable/mm_ctrl_circle"
            android:contentDescription="Pause"
            android:padding="14dp"
            android:src="@drawable/ic_pause_bars"
            app:tint="#FFFFFF" />

    </LinearLayout>

</RelativeLayout>
