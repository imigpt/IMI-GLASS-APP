<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/mm_bg_gradient">

    <!-- Header: back arrow + title -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="40dp"
        android:paddingBottom="12dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:padding="4dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Meeting Minutes"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Title pill -->
    <TextView
        android:id="@+id/tv_meeting_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/mm_title_pill"
        android:gravity="center"
        android:paddingVertical="16dp"
        android:text="Title: Health &amp; Fitness"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Recording status row -->
    <LinearLayout
        android:id="@+id/status_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_meeting_title"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:id="@+id/indicator_recording"
            android:layout_width="9dp"
            android:layout_height="9dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/recording_indicator" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎙️ Recording audio"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Live participants (hidden until detected) -->
    <TextView
        android:id="@+id/tv_live_participants"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/status_row"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="6dp"
        android:text="👥 Detecting participants…"
        android:textColor="#FF8C3A"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Center area: glowing timer OR summary generation -->
    <FrameLayout
        android:id="@+id/center_area"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/control_bar"
        android:layout_below="@id/tv_live_participants">

        <!-- Glowing timer (visible while recording) -->
        <FrameLayout
            android:id="@+id/timer_container"
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_gravity="center">

            <View
                android:layout_width="260dp"
                android:layout_height="260dp"
                android:layout_gravity="center"
                android:background="@drawable/mm_timer_glow" />

            <FrameLayout
                android:layout_width="190dp"
                android:layout_height="190dp"
                android:layout_gravity="center"
                android:background="@drawable/mm_timer_inner">

                <TextView
                    android:id="@+id/tv_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="00 :\n00"
                    android:textColor="#FFFFFF"
                    android:textSize="40sp"
                    android:textStyle="bold" />

            </FrameLayout>

        </FrameLayout>

        <!-- Summary generation (visible after meeting ends) -->
        <LinearLayout
            android:id="@+id/summary_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="Processing"
                android:src="@drawable/ic_waveform"
                app:tint="#FF8C3A" />

            <TextView
                android:id="@+id/tv_summary_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Generating Summary…"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_transcript"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Please wait while your audio is being processed.\nThis may take a few moments."
                android:textColor="#AAAAAA"
                android:textSize="13sp" />

        </LinearLayout>

    </FrameLayout>

    <!-- Bottom control bar -->
    <LinearLayout
        android:id="@+id/control_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="28dp"
        android:background="@drawable/mm_control_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="32dp"
        android:paddingVertical="14dp">

        <!-- Switch / restart -->
        <ImageView
            android:id="@+id/btn_switch"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/mm_ctrl_circle"
            android:contentDescription="Switch"
            android:padding="13dp"
            android:src="@drawable/ic_sync"
            app:tint="#FFFFFF" />

        <!-- Stop (end meeting) -->
        <ImageView
            android:id="@+id/btn_end_meeting"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:background="@drawable/mm_ctrl_stop"
            android:contentDescription="Stop meeting"
            android:padding="20dp"
            android:src="@drawable/ic_stop_square"
            app:tint="#FFFFFF" />

        <!-- Pause / resume -->
        <ImageView
            android:id="@+id/btn_pause"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/mm_ctrl_circle"
            android:contentDescription="Pause"
            android:padding="14dp"
            android:src="@drawable/ic_pause_bars"
            app:tint="#FFFFFF" />

    </LinearLayout>

</RelativeLayout>
