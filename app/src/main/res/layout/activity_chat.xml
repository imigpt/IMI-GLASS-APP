<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_comper_mark1_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <!-- ============ TOP BAR (≡  IMI AI) ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <ImageView
                android:id="@+id/btnMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Menu"
                android:padding="8dp"
                android:src="@drawable/ic_menu"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="IMI"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="AI"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ============ CONTENT (messages + empty landing overlay) ============ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvChatMessages"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:overScrollMode="ifContentScrolls"
                android:paddingTop="6dp"
                android:paddingBottom="8dp"
                android:scrollbars="vertical" />

            <!-- EMPTY-STATE LANDING (shown when conversation has no messages) -->
            <ScrollView
                android:id="@+id/layoutChatEmpty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:overScrollMode="never"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="40dp">

                    <TextView
                        android:id="@+id/tvGreetingLine1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hey there,"
                        android:textColor="#FFFFFF"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ready to chat?"
                        android:textColor="#FF7F2E"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="34dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Things you can do"
                        android:textColor="#D8D8D8"
                        android:textSize="14sp"
                        android:layout_marginBottom="14dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvSuggestions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never" />
                </LinearLayout>
            </ScrollView>
        </FrameLayout>

        <!-- ============ HIDDEN ACTION CHIPS (kept for code compatibility) ============ -->
        <TextView
            android:id="@+id/chipCreateImage"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/chipSummarize"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/chipDeepThinking"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <!-- ============ COMPOSER + LISTENING (swap in same slot) ============ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="8dp">

            <!-- Normal composer: + | Ask AI | mic | send -->
            <LinearLayout
                android:id="@+id/layoutComposer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_chat_composer_v2"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="8dp">

                <ImageView
                    android:id="@+id/btnAddAttachment"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:clickable="true"
                    android:contentDescription="Add / capture"
                    android:focusable="true"
                    android:src="@drawable/ic_add"
                    app:tint="#FFFFFF" />

                <EditText
                    android:id="@+id/etChatInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Ask AI"
                    android:inputType="textMultiLine|textCapSentences"
                    android:maxLines="4"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#9A9A9A"
                    android:textSize="16sp" />

                <ImageView
                    android:id="@+id/btnVoiceInput"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="4dp"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:contentDescription="Voice input"
                    android:focusable="true"
                    android:src="@drawable/ic_mic"
                    app:tint="#CFCFCF" />

                <!-- Send button (orange circle) -->
                <ImageView
                    android:id="@+id/btnSendMessage"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_chat_send_orb"
                    android:clickable="true"
                    android:contentDescription="Send message"
                    android:focusable="true"
                    android:padding="11dp"
                    android:src="@drawable/ic_send"
                    app:tint="#FFFFFF" />
            </LinearLayout>

            <!-- Listening bar: wavy gradient + Listening + stop -->
            <LinearLayout
                android:id="@+id/layoutListening"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_chat_listening"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="8dp"
                android:visibility="gone">

                <com.sdk.glassessdksample.ui.VoiceWaveView
                    android:id="@+id/voiceWave"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="10dp"
                    android:text="Listening"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/btnStopListening"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_chat_send_orb"
                    android:clickable="true"
                    android:contentDescription="Stop listening"
                    android:focusable="true"
                    android:padding="13dp"
                    android:src="@drawable/ic_stop_square"
                    app:tint="#FFFFFF" />
            </LinearLayout>
        </FrameLayout>

        <!-- Hidden token usage label (kept for code compatibility) -->
        <TextView
            android:id="@+id/tvUserLineTokenUsage"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <!-- ============ BOTTOM NAVIGATION BAR ============ -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_home_nav"
            app:menu="@menu/menu_bottom_nav_mark1"
            app:itemIconTint="@color/home_nav_item_color"
            app:itemTextColor="@color/home_nav_item_color"
            app:itemActiveIndicatorStyle="@style/HomeNavActiveIndicator"
            app:itemRippleColor="@android:color/transparent"
            app:labelVisibilityMode="unlabeled"
            app:elevation="0dp" />
    </LinearLayout>

    <!-- ============ CONVERSATIONS DRAWER (image 3) ============ -->
    <LinearLayout
        android:id="@+id/navigationView"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#1A1919"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="40dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Conversations"
            android:textColor="#FF7F2E"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_chat_composer_v2"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="10dp"
                android:src="@drawable/ic_search"
                app:tint="#9A9A9A" />

            <EditText
                android:id="@+id/etSearchConversations"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Search Chats"
                android:inputType="text"
                android:textColor="#FFFFFF"
                android:textColorHint="#9A9A9A"
                android:textSize="15sp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvConversations"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="6dp"
            android:paddingBottom="6dp" />

        <LinearLayout
            android:id="@+id/btnNewChat"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_chat_new_chat_v2"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New Chat"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
