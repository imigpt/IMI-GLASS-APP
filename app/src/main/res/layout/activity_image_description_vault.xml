<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D0D">

    <!-- ══════════════ Header ══════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1A1A1A"
        android:elevation="4dp"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/btnVaultBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_arrow_back"
            android:tint="#FFFFFF"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="Back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔐 Image Descriptions Vault"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvVaultCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 descriptions stored"
                android:textColor="#888888"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- Clear vault button -->
        <ImageView
            android:id="@+id/btnVaultClear"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_delete"
            android:tint="#FF4444"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="Clear Vault"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- ══════════════ Search / filter bar ════════════════════════════ -->
    <EditText
        android:id="@+id/etVaultSearch"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:background="#2A2A2A"
        android:hint="🔍  Search descriptions..."
        android:textColorHint="#555555"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:imeOptions="actionSearch"
        android:inputType="text"
        android:singleLine="true" />

    <!-- ══════════════ Empty state ═════════════════════════════════════ -->
    <TextView
        android:id="@+id/tvVaultEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="No descriptions yet.\nAnalyze photos in the gallery\nto populate this vault."
        android:textColor="#555555"
        android:textSize="15sp"
        android:lineSpacingMultiplier="1.5"
        android:visibility="gone" />

    <!-- ══════════════ List ════════════════════════════════════════════ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvVault"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

</LinearLayout>
