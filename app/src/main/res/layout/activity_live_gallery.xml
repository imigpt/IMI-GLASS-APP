<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050608">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingTop="10dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_chat_icon_button"
                    android:clickable="true"
                    android:contentDescription="Back"
                    android:focusable="true"
                    android:padding="9dp"
                    android:src="@drawable/ic_back"
                    app:tint="@color/text_primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/neue_plak_regular"
                    android:gravity="center"
                    android:text="Photo album"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/btnSyncGlasses"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chat_icon_button"
                    android:clickable="true"
                    android:contentDescription="Sync"
                    android:focusable="true"
                    android:padding="8dp"
                    android:src="@drawable/ic_sync"
                    app:tint="#FFF2F5FA" />

                <ImageView
                    android:id="@+id/btnClearAll"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_chat_icon_button"
                    android:clickable="true"
                    android:contentDescription="Clear all"
                    android:focusable="true"
                    android:padding="8dp"
                    android:src="@drawable/ic_delete"
                    app:tint="#FFF2F5FA" />

                <ImageView
                    android:id="@+id/btnAnalyzeAI"
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/btnVault"
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvPhotoCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/neue_plak_regular"
                android:paddingTop="2dp"
                android:text="0 items"
                android:textColor="#FF97A5B7"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvGalleryStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/neue_plak_regular"
                android:paddingTop="2dp"
                android:text="Sync seamlessly between glasses and phone"
                android:textColor="#FF8B95A2"
                android:textSize="11sp" />

            <ProgressBar
                android:id="@+id/progressBarGallery"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginTop="6dp"
                android:indeterminate="true"
                android:indeterminateTint="#FFFA5A2E"
                android:progressTint="#FFFA5A2E"
                android:visibility="gone" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chipAll"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_gallery_chip_active"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="@font/neue_plak_regular"
                        android:gravity="center"
                        android:minWidth="64dp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="All"
                        android:textColor="@color/white"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/chipImage"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_gallery_chip_inactive"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="@font/neue_plak_regular"
                        android:gravity="center"
                        android:minWidth="72dp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="Image"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/chipVideo"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_gallery_chip_inactive"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="@font/neue_plak_regular"
                        android:gravity="center"
                        android:minWidth="72dp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="Video"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/chipRecording"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_gallery_chip_inactive"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="@font/neue_plak_regular"
                        android:gravity="center"
                        android:minWidth="92dp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="Recording"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/chipCollection"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_gallery_chip_inactive"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="@font/neue_plak_regular"
                        android:gravity="center"
                        android:minWidth="92dp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="Collection"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingBottom="8dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvGallery"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="8dp"
                android:scrollbars="none"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutEmpty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="22dp"
                android:visibility="visible">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_chat_icon_button"
                    android:padding="18dp"
                    android:src="@drawable/ic_gallery"
                    app:tint="#FF9AA8B8" />

                <TextView
                    android:id="@+id/tvEmptyTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/neue_plak_regular"
                    android:text="No media yet"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvEmptySubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/neue_plak_regular"
                    android:gravity="center"
                    android:text="Capture from your glasses, then tap sync."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btnSyncGlassesEmpty"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_gallery_chip_active"
                    android:fontFamily="@font/neue_plak_regular"
                    android:minWidth="130dp"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="Sync now"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/galleryBottomBar"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="@drawable/bg_gallery_bottom_bar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <LinearLayout
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="21dp"
                    android:layout_height="21dp"
                    android:src="@drawable/ic_home"
                    app:tint="#FF7B8695" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/neue_plak_regular"
                    android:text="Home"
                    android:textColor="#FF7B8695"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navAi"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="21dp"
                    android:layout_height="21dp"
                    android:src="@drawable/ic_ai_vision"
                    app:tint="#FF7B8695" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/neue_plak_regular"
                    android:text="AI"
                    android:textColor="#FF7B8695"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navPhoto"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_gallery"
                    app:tint="#FFFA5A2E" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/neue_plak_regular"
                    android:text="Photo"
                    android:textColor="#FFFA5A2E"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navMine"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="21dp"
                    android:layout_height="21dp"
                    android:src="@drawable/ic_profile"
                    app:tint="#FF7B8695" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/neue_plak_regular"
                    android:text="Mine"
                    android:textColor="#FF7B8695"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

