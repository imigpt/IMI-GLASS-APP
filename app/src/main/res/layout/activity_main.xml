<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="24dp">

        <!-- APP HEADER WITH STATUS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hey IMI"
                    android:textColor="@color/text_primary"
                    android:textSize="32sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.01"
                    android:includeFontPadding="false"/>
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Voice Assistant"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginTop="2dp"
                    android:letterSpacing="0.04"/>
            </LinearLayout>
            
            <!-- Status Badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_button_secondary"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:gravity="center">
                
                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/ic_status_dot"
                    android:layout_marginEnd="6dp"/>
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ready"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif"/>
            </LinearLayout>
        </LinearLayout>

        <!-- VOICE ACTIONS CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_premium"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="20dp"
            android:elevation="6dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Voice Controls"
                android:textColor="@color/accent_glow"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:textAllCaps="true"
                android:layout_marginBottom="20dp"/>

            <!-- PRIMARY VOICE BUTTON WITH ICON -->
            <Button
                android:id="@+id/btn_voice"
                android:layout_width="match_parent"
                android:layout_height="62dp"
                android:text="Voice Command"
                android:drawableStart="@drawable/ic_mic"
                android:drawablePadding="12dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:gravity="center"
                android:textColor="@color/background_primary"
                android:textSize="17sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_button_primary"
                android:textAllCaps="false"
                android:letterSpacing="0.02"
                android:elevation="4dp"
                android:stateListAnimator="@null"
                android:layout_marginBottom="14dp"/>
            
            <!-- QUICK WAKE BUTTON -->
            <Button
                android:id="@+id/btn_quick_wake"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Quick Wake"
                android:drawableStart="@drawable/ic_mic"
                android:drawablePadding="10dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:gravity="center"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="sans-serif"
                android:background="@drawable/bg_button_secondary"
                android:textAllCaps="false"
                android:letterSpacing="0.01"
                android:stateListAnimator="@null"
                android:layout_marginBottom="20dp"/>
            
            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_subtle"
                android:layout_marginBottom="18dp"/>
            
            <!-- SETTINGS TOGGLES -->
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_use_gemini_ack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Gemini Wake Response"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:checked="true"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                app:thumbTint="@color/accent_silver"
                app:trackTint="@color/divider_subtle"
                android:layout_marginBottom="4dp"/>
            
            <!-- Glass microphone switch removed to prevent automatic mic switching on wake -->
                
        </LinearLayout>

        <!-- CONVERSATION CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_premium"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp"
            android:layout_marginBottom="20dp"
            android:elevation="6dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Conversation"
                android:textColor="@color/accent_glow"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:textAllCaps="true"
                android:layout_marginBottom="16dp"/>
            
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:background="@drawable/bg_conversation_card"
                android:padding="20dp"
                android:scrollbars="none"
                android:scrollbarStyle="insideOverlay">
                
                <TextView
                    android:id="@+id/tvConversation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ready to assist you...\n"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif-light"
                    android:lineSpacingExtra="8dp"
                    android:letterSpacing="0.01"/>
            </ScrollView>
                <!-- Image preview for last captured photo (hidden by default) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    android:id="@+id/llPhotoPreview">

                    <ImageView
                        android:id="@+id/ivConversationImage"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:scaleType="centerCrop"
                        android:adjustViewBounds="true"
                        android:contentDescription="Last captured photo" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="end"
                        android:layout_marginTop="8dp">

                        <Button
                            android:id="@+id/btn_save_photo"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="Download"
                            android:background="@drawable/bg_button_secondary"
                            android:textColor="@color/text_primary"/>

                    </LinearLayout>
                </LinearLayout>

        </LinearLayout>

        <!-- GLASS CONTROLS CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_premium"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp"
            android:elevation="6dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Glass Controls"
                android:textColor="@color/accent_glow"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:textAllCaps="true"
                android:layout_marginBottom="18dp"/>

            <!-- CONNECT BUTTON -->
            <Button
                android:id="@+id/btn_bt"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Connect Glass"
                android:drawableStart="@drawable/ic_connect"
                android:drawablePadding="10dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:gravity="center"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="sans-serif"
                android:background="@drawable/bg_button_secondary"
                android:textAllCaps="false"
                android:letterSpacing="0.01"
                android:stateListAnimator="@null"
                android:layout_marginBottom="12dp"/>

            <!-- ACTION BUTTONS (2-COLUMN GRID) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                
                <Button
                    android:id="@+id/btn_camera"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:text="Photo"
                    android:drawableTop="@drawable/ic_camera"
                    android:drawablePadding="6dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:gravity="center"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"
                    android:background="@drawable/bg_button_secondary"
                    android:textAllCaps="false"
                    android:stateListAnimator="@null"
                    android:layout_marginEnd="8dp"/>
                
                <Button
                    android:id="@+id/btn_video"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:text="Video"
                    android:drawableTop="@drawable/ic_video"
                    android:drawablePadding="6dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:gravity="center"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"
                    android:background="@drawable/bg_button_secondary"
                    android:textAllCaps="false"
                    android:stateListAnimator="@null"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                
                <Button
                    android:id="@+id/btn_battery"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:text="Battery"
                    android:drawableTop="@drawable/ic_battery"
                    android:drawablePadding="6dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:gravity="center"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"
                    android:background="@drawable/bg_button_secondary"
                    android:textAllCaps="false"
                    android:stateListAnimator="@null"
                    android:layout_marginEnd="8dp"/>
                
                <Button
                    android:id="@+id/btn_version"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:text="Settings"
                    android:drawableTop="@drawable/ic_settings"
                    android:drawablePadding="6dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:gravity="center"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"
                    android:background="@drawable/bg_button_secondary"
                    android:textAllCaps="false"
                    android:stateListAnimator="@null"/>
            </LinearLayout>
            
        </LinearLayout>
        
        <!-- HIDDEN COMMAND INPUT (kept for compatibility) -->
        <EditText
            android:id="@+id/etCommand"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:visibility="gone"/>

    </LinearLayout>

</ScrollView>
