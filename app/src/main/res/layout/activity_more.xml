<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_more_screen_gradient">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="84dp"
        android:overScrollMode="never"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="40dp"
            android:paddingBottom="16dp">

            <!-- ============ TITLE ============ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Explore the New"
                android:textColor="#FF7F2E"
                android:textSize="32sp"
                android:textStyle="bold"
                android:letterSpacing="-0.01" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Experience"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold"
                android:letterSpacing="-0.01"
                android:layout_marginBottom="28dp" />

            <!-- ============ YOUR RECENTS LABEL ============ -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your Recents"
                    android:textColor="#EEFFFFFF"
                    android:textSize="15sp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/ic_arrow_down"
                    app:tint="#EEFFFFFF" />
            </LinearLayout>

            <!-- ============ RECENTS CARD (Figma: 356x243, radius 20) ============ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="243dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_more_recents_card"
                android:paddingStart="17dp"
                android:paddingEnd="17dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <!-- Live Gallery preview (Figma: 139.5 x 169.5, radius 14) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardLiveGallery"
                    android:layout_width="0dp"
                    android:layout_height="170dp"
                    android:layout_weight="139.5"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_more_live_gallery">

                        <!-- Recent photos slider -->
                        <androidx.viewpager2.widget.ViewPager2
                            android:id="@+id/pagerRecents"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />

                        <!-- Empty-state hint when no recent photos exist -->
                        <TextView
                            android:id="@+id/tvRecentsEmpty"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="No recent\nphotos yet"
                            android:gravity="center"
                            android:textColor="#CCFFFFFF"
                            android:textSize="12sp"
                            android:visibility="gone" />

                        <!-- Left arrow -->
                        <ImageView
                            android:id="@+id/btnRecentsPrev"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="start|center_vertical"
                            android:layout_marginStart="6dp"
                            android:background="@drawable/bg_more_carousel_arrow"
                            android:padding="6dp"
                            android:src="@drawable/ic_arrow_left"
                            android:clickable="true"
                            android:focusable="true"
                            app:tint="#FFFFFF" />

                        <!-- Right arrow -->
                        <ImageView
                            android:id="@+id/btnRecentsNext"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="end|center_vertical"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/bg_more_carousel_arrow"
                            android:padding="6dp"
                            android:src="@drawable/ic_arrow_right"
                            android:clickable="true"
                            android:focusable="true"
                            app:tint="#FFFFFF" />

                        <!-- Caption -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|start"
                            android:layout_marginStart="12dp"
                            android:layout_marginBottom="12dp"
                            android:text="Live Gallery"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:shadowColor="#000000"
                            android:shadowDx="0"
                            android:shadowDy="1"
                            android:shadowRadius="4" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Spacer between tile and pills (Figma gap ~12) -->
                <Space
                    android:layout_width="12dp"
                    android:layout_height="match_parent" />

                <!-- Right column: Camera + Vision Chat (Figma pills 151 x 70.2) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="170dp"
                    android:layout_weight="151"
                    android:orientation="vertical"
                    android:gravity="center_vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardCamera"
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:layout_marginBottom="12dp"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="64dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:background="@drawable/bg_more_action_pill">

                            <ImageView
                                android:layout_width="21dp"
                                android:layout_height="21dp"
                                android:src="@drawable/ic_camera"
                                app:tint="#FFFFFF" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:text="Camera"
                                android:textColor="#FFFFFF"
                                android:textSize="16sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardVisionChat"
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="64dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:background="@drawable/bg_more_action_pill">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_chat"
                                app:tint="#FFFFFF" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:text="Vision Chat"
                                android:textColor="#FFFFFF"
                                android:textSize="16sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </LinearLayout>

            <!-- ============ QUICK NOTE ROWS ============ -->

            <!-- Quick Notes -->
            <LinearLayout
                android:id="@+id/cardQuickNotes"
                android:layout_width="match_parent"
                android:layout_height="74dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_more_quick_note"
                android:paddingStart="14dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="9dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_more_note_icon"
                    android:padding="9dp"
                    android:src="@drawable/ic_note"
                    app:tint="#ADADAD" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="Quick Note"
                    android:textColor="#ADADAD"
                    android:textSize="16sp" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#FFFFFF" />
            </LinearLayout>

            <!-- Meeting Minutes -->
            <LinearLayout
                android:id="@+id/cardMeetingMinutes"
                android:layout_width="match_parent"
                android:layout_height="74dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_more_quick_note"
                android:paddingStart="14dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="9dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_more_note_icon"
                    android:padding="9dp"
                    android:src="@drawable/ic_note"
                    app:tint="#ADADAD" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="Meeting Minutes"
                    android:textColor="#ADADAD"
                    android:textSize="16sp" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#FFFFFF" />
            </LinearLayout>

            <!-- Conversation History -->
            <LinearLayout
                android:id="@+id/cardConversationHistory"
                android:layout_width="match_parent"
                android:layout_height="74dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_more_quick_note"
                android:paddingStart="14dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="9dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_more_note_icon"
                    android:padding="9dp"
                    android:src="@drawable/ic_note"
                    app:tint="#ADADAD" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="Conversation History"
                    android:textColor="#ADADAD"
                    android:textSize="16sp" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#FFFFFF" />
            </LinearLayout>

            <!-- AI Chat -->
            <LinearLayout
                android:id="@+id/cardChat"
                android:layout_width="match_parent"
                android:layout_height="74dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_more_quick_note"
                android:paddingStart="14dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="9dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_more_note_icon"
                    android:padding="9dp"
                    android:src="@drawable/ic_chat"
                    app:tint="#ADADAD" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="AI Chat"
                    android:textColor="#ADADAD"
                    android:textSize="16sp" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#FFFFFF" />
            </LinearLayout>

            <!-- User Memory (hidden) -->
            <LinearLayout
                android:id="@+id/cardUserMemory"
                android:layout_width="match_parent"
                android:layout_height="74dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_more_quick_note"
                android:paddingStart="14dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="9dp"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_more_note_icon"
                    android:padding="9dp"
                    android:src="@drawable/ic_note"
                    app:tint="#ADADAD" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="User Memory"
                    android:textColor="#ADADAD"
                    android:textSize="16sp" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#FFFFFF" />
            </LinearLayout>

            <!-- Vision Descriptions (hidden) -->
            <LinearLayout
                android:id="@+id/cardVisionDescriptions"
                android:layout_width="match_parent"
                android:layout_height="74dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_more_quick_note"
                android:paddingStart="14dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="9dp"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_more_note_icon"
                    android:padding="9dp"
                    android:src="@drawable/ic_ai_vision"
                    app:tint="#ADADAD" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="Vision Descriptions"
                    android:textColor="#ADADAD"
                    android:textSize="16sp" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#FFFFFF" />
            </LinearLayout>

            <!-- Glass Media Gallery -->
            <LinearLayout
                android:id="@+id/cardGlassGallery"
                android:layout_width="match_parent"
                android:layout_height="74dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_more_quick_note"
                android:paddingStart="14dp"
                android:paddingEnd="16dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_more_note_icon"
                    android:padding="9dp"
                    android:src="@drawable/ic_gallery"
                    app:tint="#ADADAD" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="Glass Media Gallery"
                    android:textColor="#ADADAD"
                    android:textSize="16sp" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#FFFFFF" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_home_nav"
        app:menu="@menu/menu_bottom_nav_mark1"
        app:itemIconTint="@color/home_nav_item_color"
        app:itemTextColor="@color/home_nav_item_color"
        app:itemActiveIndicatorStyle="@style/HomeNavActiveIndicator"
        app:itemRippleColor="@android:color/transparent"
        app:labelVisibilityMode="unlabeled"
        app:elevation="0dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
