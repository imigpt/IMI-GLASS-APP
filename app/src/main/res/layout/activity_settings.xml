<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_comper_mark1_screen">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="84dp"
        android:overScrollMode="never"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp">

            <!-- HEADER -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Customize your app experience and AI preferences."
                android:textColor="#AAFFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="28dp" />

            <!-- CONTINUOUS CHAT ROW -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="CONTINOUS CHAT"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchContinuousChat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:thumbTint="#FFFFFF"
                    app:trackTint="#FF7F2E" />
            </LinearLayout>

            <!-- AI RESPONSE PREFERENCES SECTION LABEL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Preferences"
                android:textColor="#DDFFFFFF"
                android:textSize="15sp"
                android:layout_marginBottom="10dp" />

            <!-- AI RESPONSE PREFERENCES CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#CC1A1A1A"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Customize how Imi talks to you — answer length, tone, and how it greets you."
                        android:textColor="#AAFFFFFF"
                        android:textSize="12sp"
                        android:layout_marginBottom="16dp" />

                    <!-- Answer length -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Answer length"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <Spinner
                        android:id="@+id/spinnerResponseLength"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:popupBackground="#2A2A2A"
                        android:layout_marginBottom="16dp" />

                    <!-- Tone -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tone"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <Spinner
                        android:id="@+id/spinnerResponseTone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:popupBackground="#2A2A2A"
                        android:layout_marginBottom="16dp" />

                    <!-- Greeting style -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Greeting"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <Spinner
                        android:id="@+id/spinnerGreetingStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:popupBackground="#2A2A2A"
                        android:layout_marginBottom="14dp" />

                    <!-- Custom greeting (shown only when "Custom" is selected) -->
                    <LinearLayout
                        android:id="@+id/layoutCustomGreeting"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginBottom="14dp">

                        <EditText
                            android:id="@+id/etCustomGreeting"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="e.g. Hey, Imi here — what's up?"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#77FFFFFF"
                            android:textSize="14sp"
                            android:inputType="textCapSentences"
                            android:maxLines="2"
                            android:background="@android:color/transparent"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#33FFFFFF" />
                    </LinearLayout>

                    <!-- Use my name in greeting -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Use my name in greeting"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchUseName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            app:thumbTint="#FFFFFF"
                            app:trackTint="#FF7F2E" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- USAGE LIMITS SECTION LABEL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Usage Limits"
                android:textColor="#DDFFFFFF"
                android:textSize="15sp"
                android:layout_marginBottom="10dp" />

            <!-- USAGE LIMITS CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#CC1A1A1A"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Monitor your daily usage and remaining credits."
                        android:textColor="#AAFFFFFF"
                        android:textSize="12sp"
                        android:layout_marginBottom="14dp" />

                    <!-- Current plan -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Current plan"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tvPlanPrice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Starter Plan – ₹0/month"
                        android:textColor="#AAFFFFFF"
                        android:textSize="12sp"
                        android:layout_marginBottom="20dp" />

                    <!-- Voice Chat -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Voice Chat"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvVoiceCalls"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 / 15"
                            android:textColor="#AAFFFFFF"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressVoiceCalls"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="7dp"
                        android:layout_marginBottom="4dp"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="#FF7F2E"
                        android:progressBackgroundTint="#33FFFFFF" />

                    <TextView
                        android:id="@+id/tvVoiceRemaining"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Remaining : 15"
                        android:textColor="#88FFFFFF"
                        android:textSize="11sp"
                        android:layout_marginBottom="18dp" />

                    <!-- Vision -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Vision (Image/Camera)"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvSeeingCalls"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 / 5"
                            android:textColor="#AAFFFFFF"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressSeeingCalls"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="7dp"
                        android:layout_marginBottom="4dp"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="#FF7F2E"
                        android:progressBackgroundTint="#33FFFFFF" />

                    <TextView
                        android:id="@+id/tvSeeingRemaining"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Remaining : 5"
                        android:textColor="#88FFFFFF"
                        android:textSize="11sp"
                        android:layout_marginBottom="18dp" />

                    <!-- Chat -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Chat"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvChatCalls"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 / 50"
                            android:textColor="#AAFFFFFF"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressChatCalls"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="7dp"
                        android:layout_marginBottom="4dp"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="#FF7F2E"
                        android:progressBackgroundTint="#33FFFFFF" />

                    <TextView
                        android:id="@+id/tvChatRemaining"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Remaining : 50"
                        android:textColor="#88FFFFFF"
                        android:textSize="11sp"
                        android:layout_marginBottom="22dp" />

                    <!-- Upgrade Plan button -->
                    <Button
                        android:id="@+id/btnUpgradePlan"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_home_btn_orange"
                        android:text="Upgrade Plan"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:stateListAnimator="@null" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- HIDDEN VIEWS kept for SettingsActivity code compatibility -->
            <TextView
                android:id="@+id/tvCurrentPlan"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvCurrentModel"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnModelGpt"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnModelGemini"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvCurrentWakeEngine"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnWakeEngineCustom"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnWakeEngineSnowboy"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchGeminiAck"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnOpenPermissionSettings"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- BOTTOM NAVIGATION -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_home_nav"
        app:menu="@menu/menu_bottom_nav_mark1"
        app:itemIconTint="@color/home_nav_item_color"
        app:itemTextColor="@color/home_nav_item_color"
        app:itemActiveIndicatorStyle="@style/HomeNavActiveIndicator"
        app:itemRippleColor="@android:color/transparent"
        app:labelVisibilityMode="unlabeled"
        app:elevation="0dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
