<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_comper_mark1_screen"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingEnd="18dp"
    android:paddingTop="16dp"
    android:paddingBottom="8dp">

    <!-- ============ TOP BAR (≡  IMI AI) ============ -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:padding="8dp"
            android:src="@drawable/ic_menu"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="IMI"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.02" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="AI"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/ipAddressText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text=""
            android:textColor="#AAAAAA"
            android:textSize="11sp"
            android:gravity="end"
            android:ellipsize="end"
            android:singleLine="true" />
    </LinearLayout>

    <!-- ============ CHAT MESSAGES ============ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/visionChatRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:overScrollMode="ifContentScrolls"
        android:paddingTop="6dp"
        android:paddingBottom="8dp"
        android:scrollbars="vertical" />

    <!-- ============ ACTION BUTTONS ============ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btnCaptureFromGlasses"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_chat_send_orb"
            android:text="Capture"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.02" />

        <Button
            android:id="@+id/btnStopAndReturn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_btn_red_pill"
            android:text="Stop &amp; Return"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.02" />

        <!-- Hidden — kept for code compatibility -->
        <Button
            android:id="@+id/btnStartBleStream"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- ============ COMPOSER BAR ============ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="60dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_chat_composer_v2"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="8dp">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:contentDescription="Add"
                android:src="@drawable/ic_add"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="Ask AI"
                android:textColor="#9A9A9A"
                android:textSize="16sp" />

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:padding="8dp"
                android:contentDescription="Voice"
                android:src="@drawable/ic_mic"
                app:tint="#CFCFCF" />

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_chat_send_orb"
                android:contentDescription="Send"
                android:padding="11dp"
                android:src="@drawable/ic_send"
                app:tint="#FFFFFF" />
        </LinearLayout>
    </FrameLayout>

    <!-- ============ BOTTOM NAVIGATION BAR ============ -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/visionBottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_home_nav"
        app:menu="@menu/menu_bottom_nav_mark1"
        app:itemIconTint="@color/home_nav_item_color"
        app:itemTextColor="@color/home_nav_item_color"
        app:itemActiveIndicatorStyle="@style/HomeNavActiveIndicator"
        app:itemRippleColor="@android:color/transparent"
        app:labelVisibilityMode="unlabeled"
        app:elevation="0dp" />

</LinearLayout>
