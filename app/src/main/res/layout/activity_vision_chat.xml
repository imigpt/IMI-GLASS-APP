<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A">

    <!-- Header with dark theme -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#2A2A2A"
        android:orientation="vertical"
        android:padding="16dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👓 Vision Chat"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/ipAddressText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Server: Initializing..."
            android:textColor="#AAAAAA"
            android:textSize="12sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Say 'chimi' for instant vision analysis"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:textStyle="italic" />
    </LinearLayout>

    <!-- Chat Messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/visionChatRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomInfo"
        android:layout_below="@+id/headerLayout"
        android:clipToPadding="false"
        android:padding="8dp" />

    <!-- Bottom Info with dark theme -->
    <LinearLayout
        android:id="@+id/bottomInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#2A2A2A"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Capture Button -->
        <Button
            android:id="@+id/btnCaptureFromGlasses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#4CAF50"
            android:text="📸 Capture from Glasses"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="14dp"
            android:layout_marginBottom="10dp" />

        <!-- 🆕 BLE Live Streaming Button - HIDDEN (not needed) -->
        <Button
            android:id="@+id/btnStartBleStream"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#2196F3"
            android:text="🎥 Start Live Stream (BLE)"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="14dp"
            android:layout_marginBottom="10dp"
            android:visibility="gone" />

        <!-- Stop & Return Button -->
        <Button
            android:id="@+id/btnStopAndReturn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F44336"
            android:text="🛑 Stop and Return to Gemini Live"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="14dp"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📡 Waiting for images from glasses..."
            android:textColor="#AAAAAA"
            android:textSize="12sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="AI-powered vision analysis with Gemini 2.0"
            android:textColor="#888888"
            android:textSize="10sp" />
    </LinearLayout>

</RelativeLayout>
