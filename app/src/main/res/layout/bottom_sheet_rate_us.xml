<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_dark"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="14dp"
    android:paddingEnd="20dp"
    android:paddingBottom="36dp">

    <!-- Close button -->
    <ImageView
        android:id="@+id/btnCloseRateUs"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="end"
        android:background="@drawable/bg_close_circle"
        android:padding="7dp"
        android:src="@drawable/ic_close"
        android:tint="#CCFFFFFF"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Close" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="6dp"
        android:text="Rate us"
        android:textColor="#FF7F2E"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="18dp"
        android:text="We'd love your feedback!"
        android:textColor="#FFFFFF"
        android:textSize="15sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:text="Rate IMI Glasses AI and help us improve"
        android:textColor="#CCFFFFFF"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="28dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/star1"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="6dp"
            android:src="@drawable/ic_star_filled"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="1 star" />

        <ImageView
            android:id="@+id/star2"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="6dp"
            android:src="@drawable/ic_star_filled"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="2 stars" />

        <ImageView
            android:id="@+id/star3"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="6dp"
            android:src="@drawable/ic_star_filled"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="3 stars" />

        <ImageView
            android:id="@+id/star4"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="6dp"
            android:src="@drawable/ic_star_filled"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="4 stars" />

        <ImageView
            android:id="@+id/star5"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_star_filled"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="5 stars" />
    </LinearLayout>

</LinearLayout>
