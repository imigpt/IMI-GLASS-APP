<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_upgrade_bottom_sheet"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="12dp"
    android:paddingEnd="20dp"
    android:paddingBottom="20dp">

    <View
        android:layout_width="44dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="#55FFFFFF" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="14dp"
        android:text="SPECIAL OFFER"
        android:textAllCaps="true"
        android:textColor="#AAFFFFFF"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvUpgradeHeadline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="6dp"
        android:text="Go Unlimited"
        android:textColor="#FF7F2E"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvUpgradeSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:text="Unlock higher limits and continue using all AI features"
        android:textColor="#CCFFFFFF"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvCurrentPlan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="Current plan: Free (₹0)"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/layoutProPlan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_upgrade_plan_option"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvProTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pro Plan"
                android:textColor="#FF7F2E"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvProPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="₹500"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvProLimits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Voice 120 | Vision 30 | Chat 300"
                android:textColor="#AAFFFFFF"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnSelectPro"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_upgrade_action_button"
                android:text="Upgrade"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutUltraPlan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_upgrade_plan_option"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvUltraTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ultra Plan"
                android:textColor="#FF7F2E"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvUltraPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="₹3000"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvUltraLimits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Voice 1000 | Vision 250 | Chat 2500"
                android:textColor="#AAFFFFFF"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnSelectUltra"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_upgrade_action_button"
                android:text="Upgrade"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvUpgradeHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:text="Upgrade now to unlock higher usage limits."
        android:textColor="#AAFFFFFF"
        android:textSize="12sp" />

    <Button
        android:id="@+id/btnKeepCurrent"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_upgrade_secondary_button"
        android:text="Not Now"
        android:textAllCaps="false"
        android:textColor="#CCFFFFFF"
        android:textStyle="bold" />

</LinearLayout>
