<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:paddingStart="24dp"
    android:paddingTop="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="22dp"
    android:background="@drawable/bg_connecting_dialog">

    <FrameLayout
        android:layout_width="150dp"
        android:layout_height="130dp"
        android:layout_marginBottom="8dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <View
            android:id="@+id/pulseRingOne"
            android:layout_width="118dp"
            android:layout_height="118dp"
            android:layout_gravity="center"
            android:alpha="0"
            android:background="@drawable/bg_connecting_pulse_ring" />

        <View
            android:id="@+id/pulseRingTwo"
            android:layout_width="118dp"
            android:layout_height="118dp"
            android:layout_gravity="center"
            android:alpha="0"
            android:background="@drawable/bg_connecting_pulse_ring" />

        <View
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_connecting_icon_halo" />

        <FrameLayout
            android:id="@+id/connectingIconHolder"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_connecting_icon_circle"
            android:elevation="2dp">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@drawable/mark1"
                android:scaleType="fitCenter" />
        </FrameLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/tvConnectingTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:maxLines="2"
        android:text="Connecting"
        android:textColor="#FFFFFF"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvConnectingSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:text="Hold steady while we sync your glasses"
        android:textColor="#AFC0CB"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ProgressBar
            android:id="@+id/progressConnecting"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="10dp"
            android:indeterminate="true"
            android:indeterminateTint="#E8F7FF" />

        <TextView
            android:id="@+id/tvConnectingState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Establishing secure link"
            android:textColor="#E8EEF2"
            android:textSize="17sp" />
    </LinearLayout>

</LinearLayout>
