<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#2A2A2A"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="New Note"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- Title Input -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Title"
        android:textColor="#888888"
        android:textSize="12sp" />

    <EditText
        android:id="@+id/et_note_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A1A"
        android:inputType="textCapSentences"
        android:maxLines="2"
        android:padding="12dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:textSize="16sp" />

    <!-- Content Input -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Note Content"
        android:textColor="#888888"
        android:textSize="12sp" />

    <EditText
        android:id="@+id/et_note_content"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="#1A1A1A"
        android:gravity="top"
        android:hint="Type your note here"
        android:inputType="textMultiLine|textCapSentences"
        android:padding="12dp"
        android:scrollbars="vertical"
        android:textColor="#FFFFFF"
        android:textColorHint="#666666"
        android:textSize="14sp" />

    <!-- Attach Photo Section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Photo Attachment"
        android:textColor="#888888"
        android:textSize="12sp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <!-- Image Preview (hidden by default) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_image_preview"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:visibility="gone"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="8dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <ImageView
                android:id="@+id/iv_note_image_preview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />

            <!-- Remove image button -->
            <ImageView
                android:id="@+id/btn_remove_image"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:background="#80000000"
                android:padding="4dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:contentDescription="Remove photo" />

        </androidx.cardview.widget.CardView>

        <!-- Attach Photo Button (shown when no image) -->
        <LinearLayout
            android:id="@+id/layout_attach_photo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A1A1A"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:id="@+id/btn_take_photo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:drawableTop="@android:drawable/ic_menu_camera"
                android:gravity="center"
                android:padding="8dp"
                android:text="📷 Take Photo"
                android:textColor="#00D9FF"
                android:textSize="13sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="40dp"
                android:background="#333333" />

            <TextView
                android:id="@+id/btn_pick_gallery"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:drawableTop="@android:drawable/ic_menu_gallery"
                android:gravity="center"
                android:padding="8dp"
                android:text="🖼️ Gallery"
                android:textColor="#00D9FF"
                android:textSize="13sp" />

        </LinearLayout>

    </FrameLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_cancel"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="#888888" />

        <Button
            android:id="@+id/btn_save"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:backgroundTint="#00D9FF"
            android:text="Save"
            android:textColor="#1A1A1A" />

    </LinearLayout>

</LinearLayout>
