<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    android:background="@drawable/mm_dialog_card_bg"
    android:clipToOutline="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="0dp">

        <!-- Header Section with Icon and Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/dialog_header_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="20dp">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/icon_circle_bg"
                android:contentDescription="Meeting"
                android:padding="11dp"
                android:src="@drawable/ic_note"
                app:tint="#FFFFFF" />

            <TextView
                android:id="@+id/tv_dialog_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="Title: Meeting Title"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Meeting Info Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Date Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/info_badge_bg"
                    android:contentDescription="Date"
                    android:padding="8dp"
                    android:src="@drawable/ic_clock"
                    app:tint="#FF8C3A" />

                <TextView
                    android:id="@+id/tv_dialog_date"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Jun 15, 2026 at 12:30 pm"
                    android:textColor="#E8E0D8"
                    android:textSize="15sp" />

            </LinearLayout>

            <!-- Duration Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/info_badge_bg"
                    android:contentDescription="Duration"
                    android:padding="8dp"
                    android:src="@drawable/ic_clock"
                    app:tint="#FF8C3A" />

                <TextView
                    android:id="@+id/tv_dialog_duration"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Duration: 18s"
                    android:textColor="#E8E0D8"
                    android:textSize="15sp" />

            </LinearLayout>

            <!-- Word Count Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/info_badge_bg"
                    android:contentDescription="Words"
                    android:padding="8dp"
                    android:src="@drawable/ic_edit"
                    app:tint="#FF8C3A" />

                <TextView
                    android:id="@+id/tv_dialog_word_count"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Words: 57"
                    android:textColor="#E8E0D8"
                    android:textSize="15sp" />

            </LinearLayout>

            <!-- Speaker Count Row -->
            <LinearLayout
                android:id="@+id/layout_speaker_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/info_badge_bg"
                    android:contentDescription="Participants"
                    android:padding="8dp"
                    android:src="@drawable/ic_note"
                    app:tint="#FF8C3A" />

                <TextView
                    android:id="@+id/tv_dialog_speaker_count"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Participants: 3 speakers detected"
                    android:textColor="#FF8C3A"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- Summary Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <!-- Summary Header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:letterSpacing="0.15"
                android:paddingVertical="12dp"
                android:text="SUMMARY"
                android:textColor="#FF8C3A"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/gradient_divider" />

            <!-- Summary Content -->
            <TextView
                android:id="@+id/tv_dialog_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="4dp"
                android:text="The team discussed the progress of the free wedding app and the remaining tasks related to it."
                android:textColor="#D8D0C8"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- Transcript Section (collapsible) -->
        <LinearLayout
            android:id="@+id/layout_transcript_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="8dp"
            android:visibility="gone">

            <!-- Transcript Header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:letterSpacing="0.15"
                android:paddingVertical="12dp"
                android:text="TRANSCRIPT"
                android:textColor="#FF8C3A"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="16dp"
                android:background="#4DFF7F2E" />

            <!-- Transcript Content -->
            <TextView
                android:id="@+id/tv_dialog_transcript"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="3dp"
                android:text="Full transcript text here..."
                android:textColor="#B8B0A8"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Show Transcript Toggle Button -->
        <TextView
            android:id="@+id/btn_toggle_transcript"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:drawableStart="@drawable/ic_eye"
            android:drawablePadding="8dp"
            android:drawableTint="#FF8C3A"
            android:focusable="true"
            android:gravity="center"
            android:padding="16dp"
            android:text="Show Transcript"
            android:textColor="#FF8C3A"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Action Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end|center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="20dp">

            <TextView
                android:id="@+id/btn_dialog_delete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/mm_btn_delete_pill"
                android:clickable="true"
                android:focusable="true"
                android:paddingHorizontal="26dp"
                android:paddingVertical="10dp"
                android:text="Delete"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_dialog_close"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="12dp"
                android:text="Close"
                android:textColor="#E8E0D8"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
