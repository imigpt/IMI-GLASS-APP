<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_switch_device_dialog"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="28dp"
    android:paddingBottom="24dp">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Switch Device"
        android:textColor="#FF7F2E"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="6dp" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose one option"
        android:textColor="#AAFFFFFF"
        android:textSize="13sp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp" />

    <!-- Device option cards row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <!-- Mark I card -->
        <LinearLayout
            android:id="@+id/cardMark1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_switch_device_card_selected"
            android:layout_marginEnd="10dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IMI"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MARK I"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="10dp" />

            <ImageView
                android:layout_width="72dp"
                android:layout_height="40dp"
                android:src="@drawable/glasses_mark1"
                android:scaleType="fitCenter" />
        </LinearLayout>

        <!-- Mark II card -->
        <LinearLayout
            android:id="@+id/cardMark2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_switch_device_card_plain"
            android:layout_marginStart="10dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IMI"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MARK II"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="10dp" />

            <ImageView
                android:layout_width="72dp"
                android:layout_height="40dp"
                android:src="@drawable/glasses_mark2"
                android:scaleType="fitCenter" />
        </LinearLayout>
    </LinearLayout>

    <!-- Switch button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSwitchConfirm"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Switch"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        app:backgroundTint="#FF7F2E"
        app:cornerRadius="25dp"
        android:layout_marginBottom="12dp" />

    <!-- Not Now -->
    <TextView
        android:id="@+id/btnNotNow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Not Now"
        android:textColor="#88FFFFFF"
        android:textSize="14sp"
        android:layout_gravity="center_horizontal"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>
