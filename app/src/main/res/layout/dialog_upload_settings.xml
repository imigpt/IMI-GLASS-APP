<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Configure automatic photo upload to server"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <Switch
        android:id="@+id/uploadEnabledSwitch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enable Auto Upload"
        android:textSize="16sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Upload Server URL:"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/uploadUrlInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="http://your-server.com:8080/upload"
        android:inputType="textUri"
        android:textSize="14sp"
        android:padding="12dp"
        android:background="@android:drawable/edit_text" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Note: Use 10.0.2.2 for Android emulator localhost"
        android:textSize="12sp"
        android:textColor="#666666"
        android:layout_marginTop="8dp" />

</LinearLayout>
