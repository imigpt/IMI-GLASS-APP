<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_meeting"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="10dp"
    android:background="@drawable/mm_dialog_card_bg"
    android:clickable="true"
    android:clipToOutline="true"
    android:focusable="true"
    android:orientation="vertical">

    <!-- Header bar: note icon + Title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/dialog_header_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="Meeting"
            android:src="@drawable/ic_note"
            app:tint="#FF8C3A" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="Title: "
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_meeting_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Health &amp; Fitness"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- Body -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Date + duration aligned right -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end|center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_meeting_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jun 15, 2026"
                android:textColor="#B8B0A8"
                android:textSize="13sp" />

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginStart="10dp"
                android:contentDescription="Duration"
                android:src="@drawable/ic_clock"
                app:tint="#B8B0A8" />

            <TextView
                android:id="@+id/tv_meeting_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="11 min"
                android:textColor="#B8B0A8"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Status line -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Transcript saved."
            android:textColor="#E8E0D8"
            android:textSize="15sp" />

        <!-- Bottom row: word box + View + Delete -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_word_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/mm_word_box_bg"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingHorizontal="14dp"
                android:paddingVertical="11dp"
                android:text="Words: 0 words"
                android:textColor="#E8E0D8"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/btn_view_meeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/mm_btn_orange"
                android:clickable="true"
                android:focusable="true"
                android:paddingHorizontal="20dp"
                android:paddingVertical="10dp"
                android:text="View"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_delete_meeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/mm_btn_delete_pill"
                android:clickable="true"
                android:focusable="true"
                android:paddingHorizontal="18dp"
                android:paddingVertical="10dp"
                android:text="Delete"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
