<?xml version="1.0" encoding="utf-8"?>
<!-- AI-Written note card: "Writing...." label, edit/copy actions, orange title, body -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_note_ai"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="10dp"
    android:background="@drawable/qn_ai_card"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical"
    android:padding="18dp">

    <!-- Top row: "Writing...." + edit/copy -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Writing...."
            android:textColor="#FFFFFF"
            android:textSize="15sp" />

        <ImageView
            android:id="@+id/btn_ai_edit"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Edit"
            android:padding="6dp"
            android:src="@drawable/ic_edit"
            app:tint="#DDDDDD" />

        <ImageView
            android:id="@+id/btn_ai_copy"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Copy"
            android:padding="6dp"
            android:src="@drawable/ic_copy"
            app:tint="#DDDDDD" />

    </LinearLayout>

    <!-- Orange title -->
    <TextView
        android:id="@+id/tv_ai_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Jaipur – The Pink City of India"
        android:textColor="#FF8C3A"
        android:textSize="17sp"
        android:textStyle="bold" />

    <!-- Body -->
    <TextView
        android:id="@+id/tv_ai_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:lineSpacingExtra="3dp"
        android:text="Note content…"
        android:textColor="#CCCCCC"
        android:textSize="13sp" />

</LinearLayout>
