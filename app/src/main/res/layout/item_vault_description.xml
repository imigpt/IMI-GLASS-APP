<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1A1A1A"
    android:layout_marginHorizontal="10dp"
    android:layout_marginTop="8dp"
    android:padding="14dp">

    <!-- File name + timestamp row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvVaultFileName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#00D9FF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:singleLine="true" />

        <TextView
            android:id="@+id/tvVaultTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#666666"
            android:textSize="11sp"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- Description text -->
    <TextView
        android:id="@+id/tvVaultDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#CCCCCC"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginTop="6dp" />

    <!-- "Latest" badge – only shown for position 0 -->
    <TextView
        android:id="@+id/tvLatestBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="⭐ Most Recent"
        android:textColor="#FFB500"
        android:textSize="10sp"
        android:background="#33FFB500"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        android:visibility="gone" />

</LinearLayout>
