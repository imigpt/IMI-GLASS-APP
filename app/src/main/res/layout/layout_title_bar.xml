<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/titleBar"
    android:layout_width="match_parent"
    android:layout_height="@dimen/qc_dp_48"
    android:background="@android:color/white"
    android:paddingStart="4dp"
    android:paddingEnd="4dp"
    android:gravity="center_vertical">

    <!-- 🔙 Back Button -->
    <ImageView
        android:id="@+id/ivNavigateBefore"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:padding="14dp"
        android:clickable="true"
        android:focusable="true"
        android:src="@drawable/ic_navigate_before_black_44dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- 🎯 Center Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="marquee"
        android:singleLine="true"
        android:marqueeRepeatLimit="marquee_forever"
        android:gravity="center"
        android:textColor="@color/title_bar_center"
        android:textSize="@dimen/qc_sp_22"
        app:layout_constraintStart_toEndOf="@id/ivNavigateBefore"
        app:layout_constraintEnd_toStartOf="@id/tvRightText"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:text="Scan Glasses" />

    <!-- ➡ Right Text Button (Optional) -->
    <TextView
        android:id="@+id/tvRightText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/title_bar_right"
        android:textSize="@dimen/qc_sp_18"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:text="Edit" />

    <!-- Divider Line -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/title_bar_line"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
