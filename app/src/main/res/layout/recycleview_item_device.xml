<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="70dp"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="14dp"
    android:paddingBottom="14dp">

    <!-- Device Name -->
    <TextView
        android:id="@+id/rcv_device_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/rcv_device_address"
        tools:text="Smart Glasses XYZ" />

    <!-- Device Address -->
    <TextView
        android:id="@+id/rcv_device_address"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="#555555"
        android:textSize="13sp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/rcv_device_name"
        app:layout_constraintStart_toStartOf="@id/rcv_device_name"
        app:layout_constraintEnd_toStartOf="@id/rcv_device_rssi"
        tools:text="AA:BB:CC:22:33:44" />

    <!-- RSSI (Signal Strength) -->
    <TextView
        android:id="@+id/rcv_device_rssi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#888888"
        android:textSize="12sp"
        app:layout_constraintTop_toTopOf="@id/rcv_device_address"
        app:layout_constraintBottom_toBottomOf="@id/rcv_device_address"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="-65 dBm" />

    <!-- Bottom Line -->
    <View
        android:id="@+id/item_line"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#DDDDDD"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/rcv_device_address"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
